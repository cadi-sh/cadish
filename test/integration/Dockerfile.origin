# Builds the test-origin (test/origin) as a small static image for the integration
# harness. Built from the repo root context (see test/integration/docker-compose.yml).
FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -o /out/test-origin ./test/origin

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/test-origin /usr/bin/test-origin
EXPOSE 9000
# A small latency makes request-coalescing observable; tune via compose `command`.
ENTRYPOINT ["/usr/bin/test-origin", "-addr", ":9000"]
