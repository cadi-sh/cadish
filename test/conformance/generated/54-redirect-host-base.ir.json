{
  "irVersion": 9,
  "site": {
    "hosts": [
      "es.brand-a.example",
      "www.brand-b.example",
      "brand-a.example",
      "cam4you.tech555.io"
    ],
    "redirectHosts": [
      "brand-a.example",
      "cam4you.tech555.io",
      "es.brand-a.example",
      "www.brand-b.example"
    ],
    "canonicalHost": "es.brand-a.example"
  },
  "upstream": {},
  "matchers": {},
  "recv": {
    "redirect": [
      {
        "regex": "^/(.*)$",
        "status": 302,
        "target": "https://www.{host.base}/lang/{host.sub}/$1"
      }
    ]
  },
  "key": {
    "tokens": [
      {
        "kind": "host"
      },
      {
        "kind": "path"
      }
    ],
    "recipes": [
      {
        "selector": {
          "always": true
        },
        "tokens": [
          {
            "kind": "host"
          },
          {
            "kind": "path"
          }
        ]
      }
    ]
  },
  "response": {
    "ttl": [
      {
        "selKind": "default",
        "ttl": "1m0s"
      }
    ]
  },
  "deliver": {},
  "usesGeo": false,
  "edge": {
    "default": "local",
    "kvMaxBytes": 1048576
  }
}
