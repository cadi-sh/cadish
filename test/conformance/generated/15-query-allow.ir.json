{
  "irVersion": 4,
  "site": {
    "hosts": [
      "qa.example.com"
    ],
    "redirectHosts": [
      "qa.example.com"
    ],
    "canonicalHost": "qa.example.com"
  },
  "upstream": {},
  "matchers": {},
  "recv": {},
  "key": {
    "tokens": [
      {
        "kind": "method"
      },
      {
        "kind": "host"
      },
      {
        "kind": "path"
      },
      {
        "kind": "query_allow",
