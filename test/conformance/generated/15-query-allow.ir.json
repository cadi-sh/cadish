          "age",
          "ff-*",
          "genre"
        ]
      },
      {
        "kind": "header",
        "arg": "X-Variant"
      }
    ],
    "recipes": [
      {
        "selector": {
          "always": true
        },
        "tokens": [
          {
            "kind": "method"
          },
          {
            "kind": "host"
          },
          {
            "kind": "path"
          },
          {
            "kind": "query_allow",
            "allow": [
              "age",
              "ff-*",
              "genre"
            ]
          },
          {
            "kind": "header",
            "arg": "X-Variant"
          }
        ]
      }
