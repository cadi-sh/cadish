          "values": [
            "Express"
          ],
          "responsePhase": true
        }
      },
      {
        "selKind": "default",
        "ttl": "1m0s",
        "grace": "336h0m0s",
        "respHeader": {
          "kind": "resp_header",
          "name": "X-Powered-By",
          "values": [
            "Express"
          ],
          "responsePhase": true
        }
      },
      {
        "selKind": "status_in",
        "codes": [
          404
        ],
        "ttl": "10s",
        "grace": "1m0s"
      },
      {
        "selKind": "default",
        "ttl": "5s",
        "grace": "1m0s"
      }
    ],
    "storage": [
      {
        "selKind": "default",
        "tier": "ram"
      }
    ],
    "headerResp": [
      {
        "scope": {
          "always": true
        },
