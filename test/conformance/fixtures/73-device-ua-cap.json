{
  "name": "73-device-ua-cap",
  "cadishfile": "cap.example.com {\n    device_detect {\n        special ua_contains uniquepasttoken\n        default desktop\n    }\n    cache_key host path {device}\n    cache_ttl default ttl 60s\n    header X-Device-Class {device}\n    header +cache_status X-Cache\n}",
  "cases": [
    {
      "request": {
        "method": "GET",
        "host": "cap.example.com",
        "path": "/p",
        "header": {
          "User-Agent": [
            "uniquepasttoken short ua"
          ]
        }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": [
            "text/html"
          ]
        }
      },
      "cacheStatus": "MISS"
    },
    {
      "request": {
        "method": "GET",
        "host": "cap.example.com",
        "path": "/p",
        "header": {
          "User-Agent": [
            "Mozilla/5.0  uniquepasttoken"
          ]
        }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": [
            "text/html"
          ]
        }
      },
      "cacheStatus": "MISS"
    }
  ]
}
