{
  "name": "17-scoped-cache-key",
  "cadishfile": "example.com {\n    @ssr header X-IS-SSR-URL true\n    cache_key @ssr     host path\n    cache_key default  host url\n    cache_ttl default ttl 1m grace 5m\n    header +cache_key X-Cache-Key\n}",
  "cases": [
    {
      "request": { "method": "GET", "host": "example.com", "path": "/list", "query": { "page": ["2"], "utm_source": ["mailing"] }, "header": { "X-IS-SSR-URL": ["true"] } },
      "origin": { "status": 200, "header": { "Content-Type": ["text/html"] } },
      "cacheStatus": "MISS"
    },
    {
      "request": { "method": "GET", "host": "example.com", "path": "/list", "query": { "page": ["2"], "utm_source": ["mailing"] } },
      "origin": { "status": 200, "header": { "Content-Type": ["text/html"] } },
      "cacheStatus": "MISS"
    },
    {
      "request": { "method": "GET", "host": "example.com", "path": "/" },
      "origin": { "status": 200, "header": { "Content-Type": ["text/html"] } },
      "cacheStatus": "MISS"
    }
  ]
}
