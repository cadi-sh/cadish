{
  "name": "18-header-regex-lang",
  "cadishfile": "example.com {\n    @lang_es header_regex Accept-Language (?i)^es\n    @on_www  host_regex (?i)^www\\.\n    classify {to_es} { when @on_www @lang_es -> 1 ; default -> 0 }\n    @to_es classify {to_es}==1\n    redirect @to_es 302 https://es.example.com{uri}\n\n    cache_key host path\n    cache_ttl default ttl 1m grace 5m\n}",
  "cases": [
    {
      "request": { "method": "GET", "host": "www.example.com", "path": "/registro", "header": { "Accept-Language": ["es-ES,es;q=0.9,en;q=0.8"] } },
      "origin": { "status": 0 },
      "cacheStatus": "MISS"
    },
    {
      "request": { "method": "GET", "host": "www.example.com", "path": "/registro", "header": { "Accept-Language": ["en-US,en;q=0.9"] } },
      "origin": { "status": 200, "header": { "Content-Type": ["text/html"] } },
      "cacheStatus": "MISS"
    },
    {
      "request": { "method": "GET", "host": "es.example.com", "path": "/registro", "header": { "Accept-Language": ["es-ES,es;q=0.9"] } },
      "origin": { "status": 200, "header": { "Content-Type": ["text/html"] } },
      "cacheStatus": "MISS"
    },
    {
      "request": { "method": "GET", "host": "www.example.com", "path": "/registro", "header": { "Accept-Language": ["ES-es"] } },
      "origin": { "status": 0 },
      "cacheStatus": "MISS"
    },
    {
      "request": { "method": "GET", "host": "www.example.com", "path": "/registro" },
      "origin": { "status": 200, "header": { "Content-Type": ["text/html"] } },
      "cacheStatus": "MISS"
    }
  ]
}
