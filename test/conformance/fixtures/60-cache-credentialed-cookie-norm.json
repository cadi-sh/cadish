{
  "name": "60-cache-credentialed-cookie-norm",
  "cadishfile": "example.com {\n    @rm path_regex ^/v3/readmodel/cache/\n    cache_credentialed @rm\n    cookie_allow session\n    cache_key host path\n    cache_ttl @rm from_header X-Cache-Ttl\n    cache_ttl default hit_for_miss 0s\n    header +cache_status X-Cache\n}",
  "cases": [
    {
      "name": "scope-and-signal-survive-cookie-allow",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/home",
        "header": { "Cookie": ["session=alice; tracking=abc"] }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": ["application/json"],
          "X-Cache-Ttl": ["60"]
        }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "set-cookie-with-signal-stores-cookie-stripped",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/onlineusersnumber",
        "header": { "Cookie": ["session=alice; tracking=abc"] }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": ["application/json"],
          "X-Cache-Ttl": ["60"],
          "Set-Cookie": ["FLYING_SPAGUETTI_MONSTER_PRODUCTION=track; Path=/"]
        }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "no-signal-not-stored-failclosed",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/favorites",
        "header": { "Cookie": ["session=alice; tracking=abc"] }
      },
      "origin": {
        "status": 200,
        "header": { "Content-Type": ["application/json"] }
      },
      "cacheStatus": "MISS"
    }
  ]
}
