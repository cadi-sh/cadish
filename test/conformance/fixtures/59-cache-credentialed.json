{
  "name": "59-cache-credentialed",
  "cadishfile": "example.com {\n    @rm path_regex ^/v3/readmodel/cache/\n    cache_credentialed @rm\n    cache_key host path\n    cache_ttl @rm from_header X-Cache-Ttl\n    cache_ttl default hit_for_miss 0s\n    header +cache_status X-Cache\n}",
  "cases": [
    {
      "name": "positive-signal-stores-overriding-weak-controls",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/home",
        "header": { "Cookie": ["session=alice"] }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": ["application/json"],
          "X-Cache-Ttl": ["60"],
          "Pragma": ["no-cache"],
          "Expires": ["Thu, 01 Jan 1981 00:00:00 GMT"],
          "Cache-Control": ["no-store, private"]
        }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "set-cookie-with-signal-stores-cookie-stripped",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/onlineusersnumber",
        "header": { "Cookie": ["session=alice"] }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": ["application/json"],
          "X-Cache-Ttl": ["60"],
          "Set-Cookie": ["FLYING_SPAGUETTI_MONSTER_PRODUCTION=track; Path=/"],
          "Cache-Control": ["no-store, no-cache, must-revalidate"],
          "Pragma": ["no-cache"]
        }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "set-cookie-no-signal-not-stored",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/favorites",
        "header": { "Cookie": ["session=alice"] }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": ["application/json"],
          "Set-Cookie": ["session=fresh; Path=/; HttpOnly"]
        }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "vary-uncovered-with-signal-stores",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/home",
        "header": { "Cookie": ["session=alice"] }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": ["application/json"],
          "X-Cache-Ttl": ["60"],
          "Vary": ["Cookie"]
        }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "no-signal-not-stored-failclosed",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/communityconfiguser",
        "header": { "Cookie": ["session=alice"] }
      },
      "origin": {
        "status": 200,
        "header": { "Content-Type": ["application/json"] }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "authorization-positive-signal-stores",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/home",
        "header": { "Authorization": ["Bearer alice"] }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": ["application/json"],
          "X-Cache-Ttl": ["30"]
        }
      },
      "cacheStatus": "MISS"
    }
  ]
}
