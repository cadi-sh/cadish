{
  "name": "64-cache-credentialed-static-default",
  "cadishfile": "example.com {\n    @rm path_regex ^/v3/readmodel/cache/\n    cache_credentialed @rm\n    cache_key host path\n    cache_ttl @rm from_header X-Cache-Ttl\n    cache_ttl default ttl 60s\n    header +cache_status X-Cache\n}",
  "cases": [
    {
      "name": "static-default-no-signal-set-cookie-refused-not-credentialed-share",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/favorites",
        "header": { "Cookie": ["session=alice"] }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": ["application/json"],
          "Set-Cookie": ["session=private-for-alice; Path=/; HttpOnly"]
        }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "static-default-no-signal-no-cookie-refused-not-credentialed-share",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/communityconfiguser",
        "header": { "Cookie": ["session=alice"] }
      },
      "origin": {
        "status": 200,
        "header": { "Content-Type": ["application/json"] }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "from-header-signal-still-credentialed-stores-shared",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/v3/readmodel/cache/home",
        "header": { "Cookie": ["session=alice"] }
      },
      "origin": {
        "status": 200,
        "header": {
          "Content-Type": ["application/json"],
          "X-Cache-Ttl": ["60"],
          "Set-Cookie": ["track=for-alice; Path=/"]
        }
      },
      "cacheStatus": "MISS"
    },
    {
      "name": "out-of-scope-static-default-normal-cacheable",
      "request": {
        "method": "GET",
        "host": "example.com",
        "path": "/static/asset.css",
        "header": {}
      },
      "origin": {
        "status": 200,
        "header": { "Content-Type": ["text/css"] }
      },
      "cacheStatus": "MISS"
    }
  ]
}
